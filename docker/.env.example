# ISE Read-Only MCP Server — environment variables
# Copy this file to .env and fill in real values. .env is gitignored.

# Required: hostname or IP of the ISE Primary Administration Node (PAN). No scheme.
ISE_HOST=ise-ppan.corp.local

# Required: ISE admin username with API access.
ISE_USERNAME=apiuser

# Required: password for ISE_USERNAME. Never commit a real password.
ISE_PASSWORD=changeme

# Optional: set to "no" to skip TLS verification for self-signed lab certs.
# Default: yes (verify TLS)
ISE_VERIFY_SSL=yes

# Optional: JSON byte cap per tool response. Increase for large-window models.
# Default: 120000 (~30k tokens)
ISE_MAX_RESPONSE_BYTES=120000
